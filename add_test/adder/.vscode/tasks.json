{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "cargo: build",
            "type": "cargo",
            "command": "build",
            "args": [
                "--bin=adder",
                "--package=adder"
            ],
            "problemMatcher": [
                "$rustc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            }
        },
        {
            "label": "cargo: run",
            "type": "cargo",
            "command": "run",
            "args": [
                "--bin=adder",
                "--package=adder"
            ],
            "problemMatcher": [
                "$rustc"
            ],
            "group": "test"
        }
    ]
}

